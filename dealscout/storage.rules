rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size < 5 * 1024 * 1024; // 5MB max
    }
    
    // User profile pictures
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isOwner(userId) && isValidImage();
    }
    
    // Merchant logos and images
    match /merchants/{merchantId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated(); // Verified by Cloud Function
    }
    
    // Deal images
    match /deals/{dealId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated(); // Verified by Cloud Function
    }
    
    // Review images
    match /reviews/{reviewId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && isValidImage();
    }
    
    // Receipt images for cashback
    match /receipts/{userId}/{fileName} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() && isOwner(userId) && isValidImage();
    }
    
    // Coupon QR codes
    match /coupons/{couponId}/{fileName} {
      allow read: if true;
      allow write: if false; // Only server-side upload
    }
    
    // Public assets (app icons, etc.)
    match /public/{fileName} {
      allow read: if true;
      allow write: if false;
    }
  }
}
